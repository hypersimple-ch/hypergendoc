# Public development origin
APP_ORIGIN=http://localhost:8080

# PostgreSQL (replace every production value)
POSTGRES_DB=hypergendoc
POSTGRES_USER=hypergendoc
POSTGRES_PASSWORD=dev-only-change-me
DATABASE_URL=postgresql://hypergendoc:dev-only-change-me@postgres:5432/hypergendoc

# Private S3-compatible storage
S3_ENDPOINT=http://object-store:9000
S3_REGION=us-east-1
S3_BUCKET=hypergendoc-private
S3_ACCESS_KEY=hypergendoc-dev
S3_SECRET_KEY=dev-only-change-me-too

# Authentication and mail
BETTER_AUTH_SECRET=dev-only-32-byte-secret-change-me
# Use a distinct high-entropy value outside development; never commit it.
CREDENTIAL_PEPPER=dev-only-credential-pepper-change-me
SMTP_URL=smtp://mail.invalid:1025
MAIL_FROM=HyperGenDoc <noreply@example.invalid>

# Internal renderer IPC
RENDERER_SOCKET=/run/hypergendoc/renderer.sock
RENDER_TIMEOUT_MS=30000

# Application
NODE_ENV=development
LOG_LEVEL=info
