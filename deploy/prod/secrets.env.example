# Copy to secrets.env, chmod 600, and replace every value before deployment.
# This file is intentionally not consumed unless passed as --env-file by ops scripts.
IMAGE_TAG=replace-with-immutable-release-tag
APP_ORIGIN=https://docs.example.com
POSTGRES_DB=hypergendoc
POSTGRES_USER=hypergendoc
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://hypergendoc:replace-with-a-long-random-password@postgres:5432/hypergendoc
S3_ENDPOINT=http://object-store:3900
S3_REGION=garage
S3_BUCKET=hypergendoc-private
# S3_ACCESS_KEY must be GK followed by 32 hexadecimal characters.
S3_ACCESS_KEY=GK0123456789abcdef0123456789abcdef
# Replace both 64-hex-character placeholders with distinct random values before deployment.
S3_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GARAGE_RPC_SECRET=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
CREDENTIAL_PEPPER=replace-with-a-distinct-long-random-secret
SMTP_URL=smtps://mail.example.com:465
MAIL_FROM=HyperGenDoc <noreply@example.com>
RENDER_TIMEOUT_MS=30000
LOG_LEVEL=info
